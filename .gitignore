# =============================================================================
# SECRETS / ENVIRONMENT (CRITICAL - NEVER COMMIT)
# =============================================================================
.env
.env.*
*.pem
*.key
secrets/
*.token

# =============================================================================
# PYTHON (uv + standard)
# =============================================================================
# Virtual environments (created per subproject with uv)
.venv/
venv/
env/
ENV/

# Python caches and build artifacts
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# uv / pip / packaging
uv.lock
pip-log.txt
pip-delete-this-directory.txt

# Testing & linting caches
.pytest_cache/
.ruff_cache/
.mypy_cache/
.pytype/
.coverage
htmlcov/

# =============================================================================
# NODE.JS (cli/oteemo-assistant and any other Node packages)
# =============================================================================
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
package-lock.json   # decide per workflow; current project has one
yarn.lock
pnpm-lock.yaml

# Build output (e.g. from the Ink assistant)
cli/oteemo-assistant/dist/
dist/

# =============================================================================
# SCENARIO / ODRS GENERATED ARTIFACTS (traces, reports, runs)
# =============================================================================
# Oteemo-specific generated run traces and optimization reports
# Keep the source firm init snapshot (ontology-derived reference data)
mcp-servers/scenario-research/oteemo/data/oteemo_billable_*.json
mcp-servers/scenario-research/oteemo/data/traces/
mcp-servers/scenario-research/oteemo/reports/

# General pattern for scenario outputs (SQLite for scaffold scenarios, JSON traces, reports)
**/data/*.db
**/traces/
**/reports/*.md
**/reports/*.json
mcp-servers/scenario-research/.context/

# Keep committed reference data
!mcp-servers/scenario-research/oteemo/data/oteemo_firm_init.yaml
!mcp-servers/scenario-research/oteemo/ontology/**

# =============================================================================
# LOCAL DATABASES / VOLUMES (from templates/local-dbs/docker-compose.yml)
# =============================================================================
# Created when running local Weaviate/Postgres/Surreal compose for memory/context
weaviate_data/
postgres_data/
surreal_data/
*.db

# =============================================================================
# VECTOR / MEMORY INDEXES (turbovec, context-forge, research-memory)
# =============================================================================
.turbovec/
*.turbovec-index
*.turbovec

# =============================================================================
# IDE / EDITOR / OS
# =============================================================================
.idea/
.vscode/
*.swp
*.swo
*~
.DS_Store
Thumbs.db
*.sublime-project
*.sublime-workspace

# =============================================================================
# MISC PROJECT-SPECIFIC
# =============================================================================
# Any local bootstrap, one-off outputs, or temp files
*.log
*.tmp
*.bak
.cache/
tmp/

# Batch/orchestrator outputs (if run locally outside of intended artifact dirs)
batch-results/
out/

# Any local Docker volume mounts or data dirs not already covered
volumes/
# Strengthen cache ignore for hypothesis (pytest) in subpackages
**/.hypothesis/
.hypothesis/
