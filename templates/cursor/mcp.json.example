{
  "mcpServers": {
    "deep-research": {
      "command": "uvx",
      "args": ["deep-research-mcp"],
      "env": {
        "PERPLEXITY_API_KEY": "",
        "XAI_API_KEY": "",
        "DEEP_RESEARCH_TIMEOUT_SEC": "1800"
      }
    },
    "batch-orchestrator": {
      "command": "uvx",
      "args": ["batch-orchestrator-mcp"],
      "env": {
        "PERPLEXITY_API_KEY": "",
        "XAI_API_KEY": "",
        "OPENAI_API_KEY": ""
      }
    },
    "context-forge": {
      "command": "python",
      "args": ["$META_UTILITIES_HOME/skills/context-forge/scripts/mcp_server_example.py"],
      "env": {
        "WEAVIATE_URL": "http://localhost:8080",
        "TURBOVEC_BIT_WIDTH": "4",
        "COMPRESS_MAX_TOKENS": "4000"
      }
    },
    "research-memory": {
      "command": "uvx",
      "args": ["research-memory"]
    },
    "firecrawl": {
      "command": "npx",
      "args": ["-y", "@mendable/firecrawl-mcp"],
      "env": { "FIRECRAWL_API_KEY": "" }
    }
  }
}
